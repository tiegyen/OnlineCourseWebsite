@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="admin-content">
    <div class="admin-header" style="display: flex; flex-direction: column; align-items: center; text-align: center; margin-bottom: 20px;">
        <h2>Create New Instructor Account</h2>
        <p class="text-link">Register login credentials and profile details for a new teacher.</p>
    </div>

    <div class="card-box mt-30" style="max-width: 650px; margin-left: auto; margin-right: auto;">
        @using (Html.BeginForm("CreateInstructor", "Admin", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            @Html.ValidationSummary(true, "", new { @style = "color: #ef4444; margin-bottom: 15px; font-weight: bold; list-style: none; padding: 0;" })

            <h3 style="border-bottom: 1px solid #e2e8f0; padding-bottom: 8px; margin-bottom: 15px; color: #1e293b;"><i class="fa fa-lock"></i> Account Credentials</h3>

            <div class="quick-form-group mb-20">
                <label>Email Address</label>
                <input type="email" name="Email" class="form-control" placeholder="example@instructor.com" required />
            </div>

            <div class="quick-form-group mb-20">
                <label>Password</label>
                <input type="password" name="Password" class="form-control" placeholder="••••••••" required />
            </div>

            <h3 style="border-bottom: 1px solid #e2e8f0; padding-bottom: 8px; margin-bottom: 15px; color: #1e293b; mt-30"><i class="fa fa-id-card"></i> Personal Profile</h3>

            <div class="quick-form-group mb-20">
                <label>Full Name</label>
                <input type="text" name="FullName" class="form-control" placeholder="Dr. John Doe" required />
            </div>

            <div class="quick-form-group mb-20">
                <label>Phone Number</label>
                <input type="text" name="Phone" class="form-control" placeholder="0901234567" />
            </div>

            <div class="quick-form-group mb-20">
                <label>Address</label>
                <input type="text" name="Address" class="form-control" placeholder="District 1, HCM City" />
            </div>

            <div class="quick-form-group mb-20">
                <label>Biography & Expertise</label>
                <textarea name="Bio" class="form-control" rows="4" placeholder="Years of experience, core technologies, certificates..."></textarea>
            </div>

            <div class="mt-30" style="text-align: center;">
                <button type="submit" class="btn-admin-submit" style="width: auto; padding: 10px 30px;">Create Account</button>
                <div class="mt-15">
                    <a href="@Url.Action("Users", "Admin")" class="text-link"><i class="fa fa-arrow-left"></i> Back to Users List</a>
                </div>
            </div>
        }
    </div>
</div>