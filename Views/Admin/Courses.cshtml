@model OnlineCourseWebsite.ViewModels.CoursesViewModel
@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    .admin-actions-bar {
        display: flex;
        justify-content: flex-end;
        margin-bottom: 20px;
    }

    .btn-add-primary {
        background-color: #3498db;
        color: #fff;
        padding: 10px 16px;
        border: none;
        border-radius: 4px;
        font-weight: 500;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .btn-add-primary:hover {
            background-color: #2980b9;
        }

    /* Modal Styling */
    .custom-modal {
        display: none;
        position: fixed;
        z-index: 9999;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0,0,0,0.5);
        align-items: center;
        justify-content: center;
    }

    .modal-content-box {
        background-color: #fff;
        padding: 25px;
        border-radius: 8px;
        width: 100%;
        max-width: 600px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.15);
        animation: fadeIn 0.3s ease;
    }

    .modal-header-custom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #e2e8f0;
        padding-bottom: 15px;
        margin-bottom: 20px;
    }

    .modal-close-btn {
        background: none;
        border: none;
        font-size: 20px;
        cursor: pointer;
        color: #64748b;
    }

    .form-grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }

    .form-group-custom {
        margin-bottom: 15px;
    }

        .form-group-custom label {
            display: block;
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 6px;
            color: #334155;
        }

    .form-control-custom {
        width: 100%;
        padding: 8px 12px;
        border: 1px solid #cbd5e1;
        border-radius: 4px;
        font-size: 14px;
    }

    .modal-footer-custom {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        border-top: 1px solid #e2e8f0;
        padding-top: 15px;
        margin-top: 20px;
    }

    .btn-modal-close {
        background-color: #94a3b8;
        color: white;
        border: none;
        padding: 8px 16px;
        border-radius: 4px;
        cursor: pointer;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Tiện ích sửa nhanh danh mục */
    .cat-edit-input {
        padding: 4px 8px;
        border: 1px solid #3498db;
        border-radius: 4px;
        font-size: 13px;
        width: 70%;
    }
</style>

<div class="admin-content">
    <div class="admin-header">
        <div>
            <h2>Courses & Categories Management</h2>
            <p class="text-link">Approve new courses, assign instructors, and manage system categories.</p>
        </div>
    </div>

    <div class="admin-actions-bar mt-20">
        <button class="btn-add-primary" id="btnOpenCourseModal">
            <i class="fa fa-plus"></i> Add New Course
        </button>
    </div>

    <div class="custom-modal" id="editCourseModal">
        <div class="modal-content-box">
            <div class="modal-header-custom">
                <h3><i class="fa fa-edit"></i> Edit Course</h3>
                <button class="modal-close-btn" id="btnCloseEditModalX">&times;</button>
            </div>

            @using (Html.BeginForm("EditCourse", "Admin", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()

                <input type="hidden" name="CourseID" id="edit_CourseID" />
                <input type="hidden" name="OldImage" id="edit_OldImage" />

                <div class="form-group-custom">
                    <label>Course Name</label>
                    <input type="text" name="CourseName" id="edit_CourseName" class="form-control-custom" required />
                </div>

                <div class="form-group-custom">
                    <label>Change Thumbnail (Để trống nếu giữ nguyên ảnh cũ)</label>
                    <input type="file" id="fileEditImage" name="EditImageFile" class="form-control-custom" accept="image/*" />
                    <div class="mt-10">
                        <small>Ảnh hiện tại: </small>
                        <img id="edit_PreviewImage" src="" style="width: 60px; height: 45px; object-fit: cover; border-radius: 4px; display:inline-block; vertical-align:middle;" />
                    </div>
                </div>

                <div class="form-grid-2">
                    <div class="form-group-custom">
                        <label>Price (VND)</label>
                        <input type="number" name="Price" id="edit_Price" class="form-control-custom" min="0" required />
                    </div>
                    <div class="form-group-custom">
                        <label>Duration</label>
                        <input type="text" name="Duration" id="edit_Duration" class="form-control-custom" required />
                    </div>
                </div>

                <div class="form-group-custom">
                    <label>Category</label>
                    <select name="CategoryID" id="edit_CategoryID" class="form-control-custom" required>
                        @foreach (var cat in Model.Categories)
                        {
                            <option value="@cat.CategoryID">@cat.CategoryName</option>
                        }
                    </select>
                </div>

                <div class="form-group-custom">
                    <label>Assign Instructor</label>
                    <select name="InstructorID" id="edit_InstructorID" class="form-control-custom" required>
                        @foreach (var inst in Model.Instructors)
                        {
                            <option value="@inst.InstructorID">@inst.FullName</option>
                        }
                    </select>
                </div>

                <div class="form-group-custom">
                    <label>Status</label>
                    <select name="StatusID" id="edit_StatusID" class="form-control-custom" required>
                        @if (Model.CourseStatuses != null)
                        {
                            foreach (var status in Model.CourseStatuses)
                            {
                                <option value="@status.StatusID">@status.StatusName</option>
                            }
                        }
                    </select>
                </div>

                <div class="form-group-custom">
                    <label>Description</label>
                    <textarea name="Description" id="edit_Description" class="form-control-custom" rows="4"></textarea>
                </div>

                <div class="modal-footer-custom">
                    <button type="button" class="btn-modal-close" id="btnCloseEditModalBtn">Cancel</button>
                    <button type="submit" class="btn-admin-submit" style="width: auto; background-color: #27ae60; padding: 8px 20px;">Update Course</button>
                </div>
            }
        </div>
    </div>

    <div class="admin-two-col-layout">
        <div class="admin-main-col card-box">
            <h3 class="profile-section-title mb-20"><i class="fa fa-book"></i> Global Course List</h3>
            <div class="data-table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Course Name</th>
                            <th>Category</th>
                            <th>Duration</th>
                            <th>Assign Instructor</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Courses != null && Model.Courses.Any())
                        {
                            foreach (var course in Model.Courses)
                            {
                                <tr>
                                    <td>
                                        <div style="display: flex; gap: 10px; align-items: center;">
                                            <div>
                                                <strong>@course.CourseName</strong><br>
                                                <small class="text-link">Price: @course.Price.ToString("N0")đ</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>@course.CategoryName</td>
                                    <td><span class="text-link">@course.Duration</span></td>
                                    <td>
                                        <select class="assign-select ddl-assign-instructor" data-course-id="@course.CourseID">
                                            <option value="">-- Unassigned --</option>
                                            @foreach (var inst in Model.Instructors)
                                            {
                                                <option value="@inst.InstructorID" @(inst.InstructorID == course.InstructorID ? "selected" : "")>
                                                    @inst.FullName
                                                </option>
                                            }
                                        </select>
                                    </td>
                                    <td>
                                        <span class="status-badge status-@course.StatusID">
                                            @course.StatusName
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn-action-icon text-link btn-edit-course"
                                                data-id="@course.CourseID"
                                                data-name="@HttpUtility.HtmlAttributeEncode(course.CourseName)"
                                                data-price="@course.Price.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)"
                                                data-duration="@course.Duration"
                                                data-category="@course.CategoryID"
                                                data-instructor="@course.InstructorID"
                                                data-status="@course.StatusID"
                                                data-image="@course.Image"
                                                data-description="@HttpUtility.HtmlAttributeEncode(course.Description)"
                                                title="Edit Course">
                                            <i class="fa fa-edit"></i>
                                        </button>
                                        <button class="btn-action-icon text-danger btn-delete-course" data-course-id="@course.CourseID" title="Delete Course">
                                            <i class="fa fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" style="text-align: center; padding: 20px; color: #94a3b8;">No courses available.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="admin-side-col">
            <div class="card-box mb-20">
                <h3 class="profile-section-title mb-15"><i class="fa fa-plus"></i> Add Category</h3>
                @using (Html.BeginForm("CreateCategory", "Admin", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <div class="quick-form-group">
                        <label>Category Name</label>
                        <input type="text" name="categoryName" class="form-control" placeholder="e.g., TOEIC, Business English" required>
                    </div>
                    <button type="submit" class="btn-admin-submit">Create Category</button>
                }
            </div>

            <div class="card-box">
                <h3 class="profile-section-title mb-15"><i class="fa fa-folder-open"></i> Categories</h3>
                <div class="data-table-wrapper">
                    <table class="data-table font-size-13">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th style="width: 80px; text-align: center;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cat in Model.Categories)
                            {
                                <tr id="row-category-@cat.CategoryID">
                                    <td>
                                        <span class="cat-text-label"><strong>@cat.CategoryName</strong></span>
                                        <div class="cat-edit-container" style="display: none;">
                                            <input type="text" class="cat-edit-input" value="@cat.CategoryName" />
                                            <button class="btn-action-icon text-success btn-save-cat-inline" data-cat-id="@cat.CategoryID" title="Save"><i class="fa fa-check"></i></button>
                                            <button class="btn-action-icon text-muted btn-cancel-cat-inline" title="Cancel"><i class="fa fa-times"></i></button>
                                        </div>
                                    </td>
                                    <td style="text-align: center;">
                                        <button class="btn-action-icon text-link btn-trigger-edit-cat" title="Edit Category">
                                            <i class="fa fa-pencil-square-o fa-edit"></i>
                                        </button>
                                        <button class="btn-action-icon text-danger btn-delete-category" data-cat-id="@cat.CategoryID" title="Delete Category">
                                            <i class="fa fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="custom-modal" id="courseModal">
    <div class="modal-content-box">
        <div class="modal-header-custom">
            <h3><i class="fa fa-book"></i> Add New Course</h3>
            <button class="modal-close-btn" id="btnCloseModalX">&times;</button>
        </div>

        @using (Html.BeginForm("CreateCourse", "Admin", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()

            <div class="form-group-custom">
                <label>Course Name</label>
                <input type="text" name="CourseName" class="form-control-custom" placeholder="e.g., IELTS Mastery 7.5+" required />
            </div>

            <div class="form-group-custom">
                <label>Course Thumbnail (Hình ảnh)</label>
                <input type="file" id="fileAddImage" name="ImageFile" class="form-control-custom" accept="image/*" />
                <div class="mt-10" id="previewAddContainer" style="display: none;">
                    <small>Xem trước: </small>
                    <img id="add_PreviewImage" src="" style="width: 60px; height: 45px; object-fit: cover; border-radius: 4px; display:inline-block; vertical-align:middle;" />
                </div>
            </div>

            <div class="form-grid-2">
                <div class="form-group-custom">
                    <label>Price (VND)</label>
                    <input type="number" name="Price" class="form-control-custom" min="0" value="0" required />
                </div>
                <div class="form-group-custom">
                    <label>Duration</label>
                    <input type="text" name="Duration" class="form-control-custom" placeholder="e.g., 10 Weeks, 3 Months" required />
                </div>
            </div>

            <div class="form-group-custom">
                <label>Category</label>
                <select name="CategoryID" class="form-control-custom" required>
                    <option value="">-- Select Category --</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat.CategoryID">@cat.CategoryName</option>
                    }
                </select>
            </div>

            <div class="form-group-custom">
                <label>Assign Instructor</label>
                <select name="InstructorID" class="form-control-custom" required>
                    <option value="">-- Select Instructor --</option>
                    @foreach (var inst in Model.Instructors)
                    {
                        <option value="@inst.InstructorID">@inst.FullName</option>
                    }
                </select>
            </div>

            <div class="form-group-custom">
                <label>Initial Status</label>
                <select name="StatusID" class="form-control-custom" required>
                    @if (Model.CourseStatuses != null)
                    {
                        foreach (var status in Model.CourseStatuses)
                        {
                            <option value="@status.StatusID">@status.StatusName</option>
                        }
                    }
                </select>
            </div>

            <div class="form-group-custom">
                <label>Description</label>
                <textarea name="Description" class="form-control-custom" rows="4" placeholder="Course outline details..."></textarea>
            </div>

            <div class="modal-footer-custom">
                <button type="button" class="btn-modal-close" id="btnCloseModalBtn">Cancel</button>
                <button type="submit" class="btn-admin-submit" style="width: auto; padding: 8px 20px;">Save Course</button>
            </div>
        }
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {
        // 1. Mở Modal Add Course
        $('#btnOpenCourseModal').click(function () {
            $('#courseModal').css('display', 'flex');
        });

        function closeAndResetAddModal() {
            $('#courseModal').hide();
            $('#fileAddImage').val('');
            $('#add_PreviewImage').attr('src', '');
            $('#previewAddContainer').hide();
        }

        // 2. Đóng Modal Add qua nút
        $('#btnCloseModalX, #btnCloseModalBtn').click(function () {
            closeAndResetAddModal();
        });

        // 3. Đóng các Modal khi click ra ngoài vùng xám
        $(window).click(function (e) {
            if ($(e.target).is('#courseModal')) {
                closeAndResetAddModal();
            }
            if ($(e.target).is('#editCourseModal')) {
                $('#editCourseModal').hide();
            }
        });

        // 4. AJAX Đổi Instructor nhanh trên bảng chính
        $('.ddl-assign-instructor').change(function () {
            var courseId = $(this).data('course-id');
            var instructorId = $(this).val();
            if (!instructorId) return;

            $.ajax({
                url: '@Url.Action("UpdateInstructorAssignment", "Admin")',
                type: 'POST',
                data: { courseId: courseId, instructorId: instructorId },
                success: function (response) {
                    if (response.success) {
                        alert('Instructor assigned successfully!');
                    } else {
                        alert('Failed to update assignment.');
                    }
                },
                error: function () { alert('Error system connectivity.'); }
            });
        });

        // 5. AJAX Xóa Category
        $('.btn-delete-category').click(function () {
            var catId = $(this).data('cat-id');
            var row = $('#row-category-' + catId);

            if (confirm('Are you sure you want to delete this category?')) {
                $.ajax({
                    url: '@Url.Action("DeleteCategory", "Admin")',
                    type: 'POST',
                    data: { id: catId },
                    success: function (response) {
                        if (response.success) {
                            row.fadeOut(400, function () { $(this).remove(); });
                        } else {
                            alert(response.message);
                        }
                    },
                    error: function () { alert('Error while processing delete operation.'); }
                });
            }
        });

        // 🆕 CHỨC NĂNG EDIT INLINE CHO BẢNG CATEGORY KẾ BÊN
        // Bấm nút bút chì: Ẩn chữ đi, hiện ô input và cụm nút Save/Cancel
        $('.btn-trigger-edit-cat').click(function () {
            var row = $(this).closest('tr');
            row.find('.cat-text-label').hide();
            row.find('.cat-edit-container').show();
            $(this).hide(); // Ẩn chính nút Edit đó đi tạm thời
        });

        // Bấm Cancel: Khôi phục lại trạng thái ban đầu
        $('.btn-cancel-cat-inline').click(function () {
            var row = $(this).closest('tr');
            row.find('.cat-edit-container').hide();
            row.find('.cat-text-label').show();
            row.find('.btn-trigger-edit-cat').show();
        });

        // Bấm Save (Dấu check xanh): Gọi AJAX lên Controller để cập nhật Database lập tức
       // Bấm Save (Dấu check xanh): Gọi AJAX lên Controller để cập nhật Database lập tức
        $('.btn-save-cat-inline').click(function () {
            var btn = $(this);
            var catId = btn.data('cat-id');
            var row = btn.closest('tr');
            var newName = row.find('.cat-edit-input').val().trim();

            if (newName === "") {
                alert("Category name cannot be empty!");
                return;
            }

            $.ajax({
                url: '@Url.Action("EditCategory", "Admin")',
                type: 'POST',
                data: { id: catId, categoryName: newName },
                success: function (response) {
                    if (response.success) {
                        // 1. Cập nhật text mới trên bảng danh mục (Bên phải)
                        row.find('.cat-text-label strong').text(newName);

                        // 2. Tự động đổi tên danh mục trên bảng Course chính (Bên trái)
                        $('.btn-edit-course[data-category="' + catId + '"]').each(function() {
                            var courseRow = $(this).closest('tr');
                            courseRow.find('td:eq(1)').text(newName); // Cột thứ 2 hiển thị Category Name
                        });

                        // 3. Cập nhật chữ hiển thị trong Dropdown (Select) của Modal ADD Course
                        // Tìm chính xác thẻ select nằm bên trong #courseModal
                        $('#courseModal select[name="CategoryID"] option[value="' + catId + '"]').text(newName);

                        // 4. Cập nhật luôn chữ hiển thị trong Dropdown của Modal EDIT Course cho đồng bộ
                        $('#edit_CategoryID option[value="' + catId + '"]').text(newName);

                        // Trả giao diện danh mục về chế độ xem tĩnh
                        row.find('.cat-edit-container').hide();
                        row.find('.cat-text-label').show();
                        row.find('.btn-trigger-edit-cat').show();
                    } else {
                        alert(response.message);
                    }
                },
                error: function () {
                    alert("System error connection during category update.");
                }
            });
        });


        // 6. Mở modal Edit Course và đổ dữ liệu tự động
        $('.btn-edit-course').click(function () {
            var id = $(this).attr('data-id');
            var name = $(this).attr('data-name') || '';
            var price = $(this).attr('data-price') || '0';
            var duration = $(this).attr('data-duration') || $(this).data('duration') || '';
            var category = $(this).data('category');
            var instructor = $(this).data('instructor');
            var status = $(this).data('status');
            var image = $(this).data('image') || '';
            var desc = $(this).attr('data-description') || '';

            $('#edit_CourseID').val(id);
            $('#edit_CourseName').val($('<div/>').html(name).text().trim());
            $('#edit_Price').val(parseFloat(price) || 0);
            $('#edit_Duration').val($('<div/>').html(duration).text().trim());
            $('#edit_CategoryID').val(category);
            $('#edit_InstructorID').val(instructor);
            $('#edit_StatusID').val(status);
            $('#edit_Description').val($('<div/>').html(desc).text().trim());
            $('#edit_OldImage').val(image);

            var finalImgPath = "";
            var cleanImage = image.trim();

            if (cleanImage !== "" && cleanImage.toLowerCase() !== "null") {
                if (cleanImage.toLowerCase().indexOf('content/images') !== -1) {
                    finalImgPath = cleanImage.startsWith('/') ? cleanImage : '/' + cleanImage;
                } else {
                    finalImgPath = '/Content/images/' + cleanImage;
                }
            } else {
                if (category == 1) finalImgPath = '/Content/images/pic1.jpg';
                else if (category == 2) finalImgPath = '/Content/images/pic2.jpg';
                else if (category == 3) finalImgPath = '/Content/images/pic3.jpg';
                else if (category == 4) finalImgPath = '/Content/images/pic4.jpg';
                else if (category == 5) finalImgPath = '/Content/images/pic5.jpg';
                else finalImgPath = '/Content/images/picture1.jpg';
            }

            $('#edit_PreviewImage').attr('src', finalImgPath + '?t=' + new Date().getTime()).show();
            $('#editCourseModal').css('display', 'flex');
        });

        // 7. Đóng modal Edit Course
        $('#btnCloseEditModalX, #btnCloseEditModalBtn').click(function () {
            $('#editCourseModal').hide();
        });

        // 8. Đổi ảnh preview lập tức
        $('#fileEditImage').change(function (event) {
            var input = event.target;
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#edit_PreviewImage').attr('src', e.target.result);
                };
                reader.readAsDataURL(input.files[0]);
            }
        });

        $('#fileAddImage').change(function (event) {
            var input = event.target;
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#add_PreviewImage').attr('src', e.target.result);
                    $('#previewAddContainer').show();
                };
                reader.readAsDataURL(input.files[0]);
            }
        });
    });
</script>