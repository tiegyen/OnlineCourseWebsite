@model List<OnlineCourseWebsite.Models.Review>

@{
    ViewBag.Title = "Admin Dashboard";
    ViewBag.HeaderTitle = "Global System Overview";
    ViewBag.HeaderDesc = "Root administrator command center.";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
    <div>
        <h2 style="margin: 0; color: #333;">Dashboard Statistics</h2>
    </div>
    <a href="@Url.Action("ExportStatistics", "Admin")" class="btn" style="background: #107c41; color: #fff !important; text-decoration: none; padding: 10px 16px; border-radius: 6px; font-weight: 600; display: inline-flex; align-items: center; gap: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
        <i class="fa fa-file-excel-o"></i> Export Statistics Report
    </a>
</div>

<div class="admin-stats-grid">
    <div class="stat-card">
        <div class="stat-info">
            <h3>@ViewBag.TotalCourses</h3>
            <p>Total Courses</p>
        </div>
        <div class="stat-icon"><i class="fa fa-book"></i></div>
    </div>

    <div class="stat-card">
        <div class="stat-info">
            <h3>@ViewBag.TotalStudents</h3>
            <p>Total Students</p>
        </div>
        <div class="stat-icon icon-blue"><i class="fa fa-graduation-cap"></i></div>
    </div>

    <div class="stat-card">
        <div class="stat-info">
            <h3>@ViewBag.TotalInstructors</h3>
            <p>Total Instructors</p>
        </div>
        <div class="stat-icon icon-orange"><i class="fa fa-user-secret"></i></div>
    </div>

    <div class="stat-card">
        <div class="stat-info">
            <h3>@ViewBag.TotalEnrollments</h3>
            <p>Total Enrollments</p>
        </div>
        <div class="stat-icon icon-green"><i class="fa fa-check-square-o"></i></div>
    </div>

    <div class="stat-card">
        <div class="stat-info">
            <h3>@ViewBag.TotalRevenue.ToString("N0") VND</h3>
            <p>Total Revenue</p>
        </div>
        <div class="stat-icon icon-gold"><i class="fa fa-money"></i></div>
    </div>
</div>

<div class="card-box mt-30">
    <div class="review-mod-box">
        <h3 class="profile-section-title"><i class="fa fa-star"></i> Global Reviews Moderation</h3>
        <span class="text-link" style="font-size: 13px;">Review Statistics: <strong>@ViewBag.AvgRating Avg Rating</strong></span>
    </div>

    @if (Model != null && Model.Any())
    {
        foreach (var rev in Model)
        {
            <div class="review-card" style="margin-top: 15px; margin-bottom: 15px;">
                <div class="review-header">
                    <div>
                        <span class="review-author">@rev.Student.FullName</span>
                        <small class="text-link"> on Course: <strong>@rev.Course.CourseName</strong></small>

                        <div class="review-rating">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= rev.Rating)
                                {
                                    <i class="fa fa-star"></i>
                                }
                                else
                                {
                                    <i class="fa fa-star-o"></i>
                                }
                            }
                        </div>
                    </div>

                    @using (Html.BeginForm("DeleteReview", "Admin", FormMethod.Post, new { @class = "delete-review-form" }))
                    {
                        <input type="hidden" name="reviewId" value="@rev.ReviewID" />
                        <button type="submit" class="btn-action-icon btn-delete-review" title="Delete Inappropriate Review" style="background:none; border:none; cursor:pointer;">
                            <i class="fa fa-trash"></i> Delete
                        </button>
                    }
                </div>
                <p class="review-comment">"@rev.Comment"</p>
            </div>
        }
    }
    else
    {
        <p style="text-align: center; color: #aaa; font-style: italic; padding: 20px;">No reviews available in the system yet.</p>
    }
</div>

@section scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const deleteForms = document.querySelectorAll(".delete-review-form");

            deleteForms.forEach(form => {
                form.addEventListener("submit", function (event) {
                    const confirmDelete = confirm("Are you sure you want to delete this inappropriate review from the Database?");
                    if (!confirmDelete) {
                        event.preventDefault(); // Hủy lệnh submit nếu bấm Cancel
                    }
                });
            });
        });
    </script>
}