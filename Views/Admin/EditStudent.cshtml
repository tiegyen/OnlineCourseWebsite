@model OnlineCourseWebsite.Models.Student
@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="admin-content">
    <div class="admin-header" style="display: flex; flex-direction: column; align-items: center; text-align: center; margin-bottom: 20px;">

        <div>
            <h2>Edit Student Information</h2>
            <p class="text-link">Modify profile details for student: <strong>@Model.FullName</strong></p>
        </div>
    </div>

    <div class="card-box mt-30" style="max-width: 600px; margin-left: auto; margin-right: auto;">
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.StudentID)
            @Html.HiddenFor(m => m.UserID)

            <div class="quick-form-group mb-20">
                <label>Full Name</label>
                @Html.TextBoxFor(m => m.FullName, new { @class = "form-control", required = "required" })
            </div>

            <div class="quick-form-group mb-20">
                <label>Phone Number</label>
                @Html.TextBoxFor(m => m.Phone, new { @class = "form-control" })
            </div>

            <div class="quick-form-group mb-20">
                <label>Address</label>
                @Html.TextBoxFor(m => m.Address, new { @class = "form-control" })
            </div>

            <div class="mt-30" style="text-align: center;">
                <button type="submit" class="btn-admin-submit" style="width: auto; padding: 10px 25px;">Save Changes</button>
                <div class="mt-15">
                    <a href="@Url.Action("Users", "Admin")" class="text-link"><i class="fa fa-arrow-left"></i> Back to List</a>
                </div>
            </div>
        }
    </div>
</div>