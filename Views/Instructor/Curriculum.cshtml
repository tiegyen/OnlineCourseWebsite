@model OnlineCourseWebsite.Models.Course
@{
    ViewBag.Title = "Manage Curriculum";
    Layout = "~/Views/Shared/_InsLayout.cshtml";
    var lessons = ViewBag.Lessons as List<OnlineCourseWebsite.Models.Lesson>;
}

<div class="curriculum-container">
    <div class="curriculum-header">
        <div class="header-text">
            <h2>@Model.CourseName</h2>
            <p>Quản lý giáo trình và tài liệu khóa học.</p>
        </div>
        <button class="btn-add" onclick="openAddLessonModal()">+ Add New Lesson</button>
    </div>

    @if (lessons != null && lessons.Any())
    {
        foreach (var secItem in lessons.GroupBy(l => l.SectionName))
        {
            <div class="section-block">
                <div class="section-title">@secItem.Key</div>
                <ul class="lesson-list">
                    @foreach (var lesson in secItem.OrderBy(l => l.LessonOrder))
                    {
                        <li class="lesson-row" style="display: flex; flex-direction: column; align-items: flex-start; gap: 5px; padding: 12px; border-bottom: 1px solid #eee;">
                            <div style="display: flex; justify-content: space-between; width: 100%; align-items: center;">
                                <span class="lesson-name" style="font-weight: 500;">@lesson.LessonTitle</span>
                                <div class="lesson-actions">
                                    <button class="btn-icon edit" onclick="openEditLessonModal('@lesson.LessonID', '@secItem.Key', '@HttpUtility.JavaScriptStringEncode(lesson.LessonTitle)', '@lesson.VideoURL')">
                                        <i class="fa fa-edit"></i>
                                    </button>
                                    <a href="@Url.Action("DeleteLesson", "Instructor", new { id = lesson.LessonID, courseId = Model.CourseID })"
                                       class="btn-icon delete" onclick="return confirm('Xóa bài này sẽ xóa toàn bộ tài liệu đính kèm?');">
                                        <i class="fa fa-trash"></i>
                                    </a>
                                </div>
                            </div>

                            @if (lesson.CourseMaterials != null && lesson.CourseMaterials.Any())
                            {
                                <div class="lesson-materials-preview" style="margin-left: 15px; font-size: 12px; color: #666; display: flex; flex-wrap: wrap; gap: 10px;">
                                    <span style="font-weight: 600;"><i class="fa fa-paperclip"></i> Materials:</span>
                                    @foreach (var mat in lesson.CourseMaterials)
                                    {
                                        <span class="mat-item">
                                            <i class="fa @(mat.FileName.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase) ? "fa-file-pdf-o text-danger" : "fa-file-word-o text-primary")"></i>
                                            @mat.FileName
                                        </span>
                                    }
                                </div>
                            }
                        </li>
                    }
                </ul>
            </div>
        }
    }
    else
    {
        <div style="text-align:center; padding: 40px; color:#999; font-style:italic;">Chưa có bài học nào trong giáo trình này.</div>
    }
</div>

<div class="custom-modal-overlay" id="lessonModal">
    <div class="custom-modal-box">
        <span class="close-btn" onclick="closeModal()">&times;</span>
        <h3>Lesson Details</h3>
        <div class="video-preview" id="videoContainer">
            <iframe id="lessonVideo" src="" frameborder="0" allowfullscreen></iframe>
        </div>
        <form action="@Url.Action("SaveLesson", "Instructor")" method="post" enctype="multipart/form-data">
            <input type="hidden" name="CourseID" value="@Model.CourseID" />
            <input type="hidden" name="LessonID" id="inputLessonID" value="0" />

            <div class="input-group">
                <label>Section Name</label>
                <input type="text" name="SecName" id="inputSecName" required />
            </div>
            <div class="input-group">
                <label>Lesson Title</label>
                <input type="text" name="LessonTitle" id="inputLessonTitle" required />
            </div>
            <div class="input-group">
                <label>Video URL</label>
                <input type="text" name="VideoURL" id="inputVideoURL" onchange="updateVideo(this.value)" />
            </div>

            <div class="input-group">
                <label><i class="fa fa-file-text-o"></i> Upload Lesson Material (.pdf, .doc, .docx)</label>
                <input type="file" name="UploadedMaterial" id="inputMaterial" accept=".pdf,.doc,.docx" class="form-control" style="padding: 5px;" />
                <small style="color: #888; font-size: 11px; display:block; margin-top:3px;">Chọn tệp mới nếu muốn đính kèm hoặc thay thế tài liệu bài học.</small>
            </div>

            <button type="submit" class="btn-save" style="margin-top: 15px;">Save Lesson Data</button>
        </form>
    </div>
</div>

<script>
    function updateVideo(url) {
        const videoFrame = document.getElementById('lessonVideo');
        if (!url) {
            videoFrame.src = "";
            return;
        }
        if (url.includes('youtube.com/watch?v=')) {
            videoFrame.src = "https://www.youtube.com/embed/" + url.split('v=')[1].split('&')[0];
        } else if (url.includes('youtu.be/')) {
            videoFrame.src = "https://www.youtube.com/embed/" + url.split('youtu.be/')[1].split('?')[0];
        } else {
            videoFrame.src = url;
        }
    }

    function openAddLessonModal() {
        document.getElementById('inputLessonID').value = 0;
        document.getElementById('inputSecName').value = '';
        document.getElementById('inputLessonTitle').value = '';
        document.getElementById('inputVideoURL').value = '';
        document.getElementById('inputMaterial').value = ''; // Reset ô chọn file
        document.getElementById('lessonVideo').src = "";
        document.getElementById('lessonModal').classList.add('show');
    }

    function openEditLessonModal(id, sec, title, url) {
        document.getElementById('inputLessonID').value = id;
        document.getElementById('inputSecName').value = sec;
        document.getElementById('inputLessonTitle').value = title;
        document.getElementById('inputVideoURL').value = url;
        document.getElementById('inputMaterial').value = ''; // Reset ô chọn file khi edit bài cũ

        updateVideo(url);
        document.getElementById('lessonModal').classList.add('show');
    }

    function closeModal() {
        document.getElementById('lessonModal').classList.remove('show');
    }
</script>