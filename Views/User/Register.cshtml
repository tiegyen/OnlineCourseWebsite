@{
    ViewBag.Title = "Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-50 mb-50" style="max-width: 500px;">
    <div class="card-box" style="padding: 40px; box-shadow: 0 4px 15px rgba(0,0,0,0.08); border-radius: 12px; background: #fff;">
        <h2 class="text-center" style="margin-bottom: 30px; color: #333; font-weight: 700;">Create Account</h2>

        @if (ViewBag.ErrorSystem != null)
        {
            <div style="background: #ffe0e6; color: #ff4d4d; padding: 10px; border-radius: 6px; margin-bottom: 20px; font-size: 14px; font-weight: 500; text-align: center;">
                @ViewBag.ErrorSystem
            </div>
        }

        <form action="@Url.Action("Register", "User")" method="post" id="registerForm">

            <div class="form-group" style="margin-bottom: 20px;">
                <label style="display: block; margin-bottom: 8px; font-weight: 500; color: #444;">Full Name</label>
                <input type="text" name="FullName" class="form-control" placeholder="Enter your name" value="@ViewBag.FullName" required style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 6px;">
            </div>

            <div class="form-group" style="margin-bottom: 20px;">
                <label style="display: block; margin-bottom: 8px; font-weight: 500; color: #444;">Phone Number</label>
                <input type="tel" name="Phone" class="form-control" placeholder="Enter your phone number" value="@ViewBag.Phone" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 6px;">
            </div>

            <div class="form-group" style="margin-bottom: 20px;">
                <label style="display: block; margin-bottom: 8px; font-weight: 500; color: #444;">Email Address</label>
                <input type="email" name="Email" class="form-control" placeholder="Enter your email" value="@ViewBag.Email" required style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 6px;">
                @if (ViewBag.ErrorEmail != null)
                {
                    <small style="color: #ff4d4d; font-size: 12px; margin-top: 5px; display: block;">@ViewBag.ErrorEmail</small>
                }
            </div>

            <div class="form-group" style="margin-bottom: 20px;">
                <label style="display: block; margin-bottom: 8px; font-weight: 500; color: #444;">Password</label>
                <input type="password" name="Password" class="form-control" placeholder="Create password" required style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 6px;">
            </div>

            <div class="form-group" style="margin-bottom: 20px;">
                <label style="display: block; margin-bottom: 8px; font-weight: 500; color: #444;">Confirm Password</label>
                <input type="password" name="ConfirmPassword" class="form-control" placeholder="Confirm password" required style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 6px;">
                @if (ViewBag.ErrorConfirm != null)
                {
                    <small style="color: #ff4d4d; font-size: 12px; margin-top: 5px; display: block;">@ViewBag.ErrorConfirm</small>
                }
            </div>

            <button type="submit" class="btn btn-primary w-100 mt-20" style="padding: 12px; font-weight: 600; border-radius: 6px; cursor: pointer;">Register Now</button>
        </form>

        <p class="text-center mt-20" style="color: #666; font-size: 14px; text-align: center; margin-top: 20px;">
            Already have an account? <a href="@Url.Action("Login", "User")" class="text-link" style="color: #764ba2; font-weight: 600; text-decoration: none;">Login here</a>
        </p>
    </div>
</div>