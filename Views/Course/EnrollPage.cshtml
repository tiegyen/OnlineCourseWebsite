@model OnlineCourseWebsite.Models.Course

@{
    ViewBag.Title = "Confirm Purchase";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="small-container mt-50">
    <h2>Confirm Enrollment</h2>
    <p>You are about to enroll in: <strong>@Model.CourseName</strong></p>
    <p>Price: <strong>@Model.Price.Value.ToString("N0") VNĐ</strong></p>

    @using (Html.BeginForm("ConfirmEnroll", "Course", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        <input type="hidden" name="courseID" value="@Model.CourseID" />
        <button type="submit" class="btn btn-primary">Confirm & Create Payment</button>
        <a href="@Url.Action("Details", "Course", new { id = Model.CourseID })" class="btn">Cancel</a>
    }
</div>