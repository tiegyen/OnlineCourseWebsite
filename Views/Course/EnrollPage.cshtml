@model OnlineCourseWebsite.Models.Payment

@{
    ViewBag.Title = "Complete Your Payment | English Mastery";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="header">
    @* Giữ nguyên để đồng bộ CSS Header của Layout *@
</div>

<div class="small-container mt-50 mb-50">
    <h2 class="title" style="margin-top: 40px; margin-bottom: 20px;">Course Payment</h2>

    <div class="row align-start" style="display: flex; flex-wrap: wrap; gap: 25px; align-items: flex-start;">

        <div class="payment-left-col" style="flex: 1.2; min-width: 320px;">
            <div class="card-box" style="background: #fff; padding: 25px; border-radius: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.05);">
                <h3 class="mb-20" style="color: #2c3e50; font-size: 18px; font-weight: 600; margin-bottom: 15px;">
                    <i class="fa fa-shopping-bag" style="color: #ff4757; margin-right: 8px;"></i> Order Summary
                </h3>

                <div class="table-responsive">
                    <table class="table-payment">
                        <thead>
                            <tr>
                                <th>Invoice ID</th>
                                <th>Course Name</th>
                                <th style="text-align: right;">Total Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="invoice-id">#INV-@Model.PaymentID.ToString("D4")</td>
                                <td style="font-weight: 500; color: #333;">@ViewBag.CourseName</td>
                                <td class="invoice-amount" style="text-align: right; color: #ff4757; font-size: 16px;">
                                    @(((decimal?)ViewBag.Price).GetValueOrDefault(0).ToString("N0")) VND
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="payment-right-col" style="flex: 0.8; min-width: 280px; box-shadow: 0 5px 15px rgba(0,0,0,0.05);">
            <div class="card-box" style="background: #fff; padding: 25px; border-radius: 10px;">
                <h3 class="mb-20" style="color: #2c3e50; font-size: 18px; font-weight: 600; margin-bottom: 20px;">
                    <i class="fa fa-credit-card" style="color: #764ba2; margin-right: 8px;"></i> Select Payment Method
                </h3>

                <div class="payment-method-option" style="border: 2px solid #007bff; padding: 15px; border-radius: 8px; margin-bottom: 20px; background: #f8f9fa;">
                    <h4 style="margin: 0 0 10px 0; color: #007bff; font-size: 15px;"><i class="fa fa-qrcode"></i> Option 1: VNPAY Gateway</h4>
                    <p style="font-size: 13px; color: #666; margin-bottom: 15px;">Pay safely via ATM card, Credit card, or Mobile Banking QR Code.</p>

                    @using (Html.BeginForm("PaymentWithVnPay", "Course", FormMethod.Post))
                    {
                        <input type="hidden" name="paymentId" value="@Model.PaymentID" />
                        <button type="submit" class="btn" style="background: #007bff; color: #fff; padding: 12px; font-weight: 600; width: 100%; border-radius: 6px; cursor: pointer; font-size: 14px; border: none; display: block; text-align: center;">
                            <i class="fa fa-play-circle"></i> Pay with VNPAY
                        </button>
                    }
                </div>

                <div class="payment-method-option" style="border: 1px solid #ddd; padding: 15px; border-radius: 8px;">
                    <h4 style="margin: 0 0 10px 0; color: #555; font-size: 15px;"><i class="fa fa-university"></i> Option 2: Manual Bank Transfer</h4>

                    <div class="bank-info-box" style="background: #fafafa; padding: 10px; border-radius: 6px; font-size: 13px; margin-bottom: 12px; border: 1px dashed #ccc;">
                        <p style="margin: 4px 0;"><strong>Bank:</strong> Vietcombank (VCB)</p>
                        <p style="margin: 4px 0;"><strong>Account:</strong> 1023456789</p>
                        <p style="margin: 4px 0;"><strong>Content:</strong> <span style="color: #764ba2; font-weight: bold;">PAY INV@Model.PaymentID.ToString("D4")</span></p>
                    </div>

                    @using (Html.BeginForm("ConfirmPayment", "Course", FormMethod.Post))
                    {
                        <input type="hidden" name="paymentId" value="@Model.PaymentID" />
                        <button type="submit" class="btn" style="background: #2ecc71; color: #fff; padding: 10px; font-weight: 600; width: 100%; border-radius: 6px; cursor: pointer; font-size: 13px; border: none;">
                            <i class="fa fa-check-circle"></i> Confirm Transferred (Manual)
                        </button>
                    }
                </div>

            </div>
        </div>

    </div>
</div>

