@using PagedList.Mvc; @* 🌟 Nhớ thêm dòng này ở đầu file để xài được Html.PagedListPager *@
@model PagedList.IPagedList<OnlineCourseWebsite.Models.Course>

@{
    ViewBag.Title = "Courses";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var categories = ViewBag.Categories as List<OnlineCourseWebsite.Models.Category>;
}

<div class="hero-section">
    <div class="container">
        <div class="row">
            <div class="col-2">
                <h1>Master English with<br />Industry-Leading Courses</h1>
                <p>Empower your future with expert-led curriculum and internationally recognized certifications.</p>
                <a href="@Url.Action("Course", "Course")" class="btn btn-danger">Explore Courses →</a>
            </div>
            <div class="col-2">
                <img src="@Url.Content("~/Content/images/banner1.png")" alt="Banner" />
            </div>
        </div>
    </div>
</div>

<div class="small-container mt-50" id="featured-courses">
    <h2 class="title">Available Courses</h2>

    <div class="filter-container">
        <div class="search-block">
            <input type="text" id="courseSearch" class="form-control" placeholder="Search course by name or instructor..." value="@ViewBag.CurrentSearch">
        </div>
        <div class="filter-block mt-15">
            <select id="categoryFilter" class="form-control filter-select">
                <option value="">All Categories</option>
                @if (categories != null)
                {
                    foreach (var cat in categories)
                    {
                        // Nếu ID của category trùng với ID đang lọc thì thêm thuộc tính selected vào
                        bool isSelected = ViewBag.CurrentCategory != null && (int)ViewBag.CurrentCategory == cat.CategoryID;
                        <option value="@cat.CategoryID" @(isSelected ? "selected='selected'" : "")>@cat.CategoryName</option>
                    }
                }
            </select>
        </div>
    </div>

    <div class="row" style="display: flex; flex-wrap: wrap; gap: 20px; margin-top: 30px;">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-4 card-box course-item-card" style="flex: 0 0 calc(25% - 15px); min-width: 250px; max-width: 280px; margin-bottom: 20px;">
                    @{
                        string courseImageUrl = "";

                        // 1. Kiểm tra nếu cột Image trong DB không bị null hoặc rỗng
                        if (item.Image != null && !string.IsNullOrEmpty(item.Image.ToString().Trim()))
                        {
                            string dbImageValue = item.Image.ToString().Trim();

                            // TRƯỜNG HỢP A: Nếu trong DB đã chứa sẵn đường dẫn "Content/images" (Ảnh cũ)
                            if (dbImageValue.ToLower().Contains("content/images"))
                            {
                                // Nếu nó bắt đầu bằng dấu gạch chéo "/" thì chỉ cần thêm dấu ngã "~" đằng trước
                                if (dbImageValue.StartsWith("/"))
                                {
                                    courseImageUrl = "~" + dbImageValue;
                                }
                                else if (dbImageValue.StartsWith("~/"))
                                {
                                    courseImageUrl = dbImageValue;
                                }
                                else
                                {
                                    courseImageUrl = "~/" + dbImageValue;
                                }
                            }
                            // TRƯỜNG HỢP B: Nếu trong DB chỉ lưu mỗi tên file kiểu "course_9822dc82.jpg" (Ảnh mới upload)
                            else
                            {
                                courseImageUrl = "~/Content/images/" + dbImageValue;
                            }
                        }
                        // 2. Nếu cột Image trống huơ trống hoác -> Dùng logic gán cứng theo Category làm cứu cánh
                        else
                        {
                            if (item.CategoryID == 1) { courseImageUrl = "~/Content/images/pic1.jpg"; }
                            else if (item.CategoryID == 2) { courseImageUrl = "~/Content/images/pic2.jpg"; }
                            else if (item.CategoryID == 3) { courseImageUrl = "~/Content/images/pic3.jpg"; }
                            else if (item.CategoryID == 4) { courseImageUrl = "~/Content/images/pic4.jpg"; }
                            else if (item.CategoryID == 5) { courseImageUrl = "~/Content/images/pic5.jpg"; }
                            else { courseImageUrl = "~/Content/images/picture1.jpg"; }
                        }
                    }
                    <img src="@Url.Content(courseImageUrl)" alt="@item.CourseName">

                    <span class="category-badge">@(item.Category != null ? item.Category.CategoryName : "General")</span>

                    <h4 class="mt-15 course-card-title" style="height: 44px; overflow: hidden;">@item.CourseName</h4>

                    <p class="course-card-instructor">Instructor: @(item.Instructor != null ? item.Instructor.FullName : "Updating")</p>

                    <p class="course-card-duration"><i class="fa fa-clock-o"></i> @item.Duration</p>

                    <p class="course-card-price">@string.Format("{0:C0}", item.Price)</p>

                    <div class="row mt-15 course-card-actions" style="display: flex; justify-content: space-between; align-items: center;">
                        @if (Session["StudentProfile"] == null)
                        {
                            <a href="@Url.Action("Login", "User")" class="btn btn-primary btn-enroll">Enroll Now</a>
                        }
                        else
                        {
                            <a href="@Url.Action("Enroll", "Course", new { id = item.CourseID })" class="btn btn-primary btn-enroll" style="background: #ff4757; border-color: #ff4757;">Enroll Now</a>
                        }

                        <a href="@Url.Action("Details", "Course", new { id = item.CourseID })" class="text-link link-details">Details</a>
                    </div>
                </div>
            }
        }
        else
        {
            <div style="width: 100%; text-align: center; padding: 40px 0;">
                <p style="font-style: italic; color: #888;">No courses found matching the database records.</p>
            </div>
        }
    </div>

    <div class="pagination-container" style="margin-top: 40px; text-align: center;">
        <p style="color: #666; font-style: italic; margin-bottom: 10px;">
            Page @(Model.PageCount < Model.PageNumber ? 0 : Model.PageNumber) of @Model.PageCount
        </p>
        <div class="pagination-buttons">
            @Html.PagedListPager(Model, page => Url.Action("Course", new { page, currentCategory = ViewBag.CurrentCategory, searchString = ViewBag.CurrentSearch }))
        </div>
    </div>
</div>

<style>
    .pagination-buttons ul {
        display: inline-flex;
        padding-left: 0;
        list-style: none;
        border-radius: 4px;
        gap: 5px;
    }

    .pagination-buttons li {
        display: inline;
    }

        .pagination-buttons li a, .pagination-buttons li span {
            position: relative;
            display: block;
            padding: 8px 16px;
            margin-left: -1px;
            line-height: 1.42857143;
            color: #764ba2;
            text-decoration: none;
            background-color: #fff;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-weight: 600;
        }

        .pagination-buttons li.active span {
            z-index: 3;
            color: #fff;
            background-color: #764ba2;
            border-color: #764ba2;
            cursor: default;
        }

        .pagination-buttons li a:hover {
            background-color: #eee;
        }
</style>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {

        // Hàm gom tham số và reload lại trang chuẩn chỉ
        function performSearchAndFilter() {
            var searchVal = $('#courseSearch').val().trim();
            var categoryVal = $('#categoryFilter').val();

            var url = '@Url.Action("Course", "Course")';
            var params = [];

            if (searchVal) {
                params.push('searchString=' + encodeURIComponent(searchVal));
            }
            if (categoryVal) {
                params.push('currentCategory=' + categoryVal);
            }

            if (params.length > 0) {
                url += '?' + params.join('&');
            }

            window.location.href = url;
        }

        // 1. Khi thay đổi bộ chọn Category -> Chạy lọc luôn
        $('#categoryFilter').change(function () {
            performSearchAndFilter();
        });

        // 2. Khi gõ từ khóa vào ô Search và nhấn nút ENTER trên bàn phím
        $('#courseSearch').keypress(function (e) {
            if (e.which == 13) { // 13 là mã phím Enter
                performSearchAndFilter();
            }
        });
    });
</script>