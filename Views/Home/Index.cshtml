@{
    ViewBag.Title = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Ép kiểu sạch sẽ từ namespace hệ thống
    var topSubscribedCourses = ViewBag.TopSubscribed as List<OnlineCourseWebsite.Models.Course>;
    var topRatedCourses = ViewBag.TopRated as List<OnlineCourseWebsite.Controllers.RatedCourseView>;
}

<div class="hero-section">
    <div class="container">
        <div class="row">
            <div class="col-2">
                <h1>Master English with<br />Industry-Leading Courses</h1>
                <p>Empower your future with expert-led curriculum and internationally recognized certifications.</p>
                <a href="@Url.Action("Course", "Course")" class="btn btn-danger">Explore Courses →</a>
            </div>
            <div class="col-2">
                <img src="@Url.Content("~/Content/images/banner1.png")" alt="Banner" />
            </div>
        </div>
    </div>
</div>

<div class="small-container mt-50">
    <h2 class="title">Course Categories</h2>
    <div class="row" style="display: flex; justify-content: center; flex-wrap: wrap; gap: 20px;">
        <div class="col-3" style="flex: 1; min-width: 180px;"><img src="@Url.Content("~/Content/images/pic1.jpg")" alt="IELTS"><h3 class="text-center mt-15">IELTS Preparation</h3></div>
        <div class="col-3" style="flex: 1; min-width: 180px;"><img src="@Url.Content("~/Content/images/pic2.jpg")" alt="TOEIC"><h3 class="text-center mt-15">TOEIC Training</h3></div>
        <div class="col-3" style="flex: 1; min-width: 180px;"><img src="@Url.Content("~/Content/images/pic3.jpg")" alt="TOEFL"><h3 class="text-center mt-15">TOEFL Prep</h3></div>
        <div class="col-3" style="flex: 1; min-width: 180px;"><img src="@Url.Content("~/Content/images/pic4.jpg")" alt="Communication"><h3 class="text-center mt-15">English Communication</h3></div>
        <div class="col-3" style="flex: 1; min-width: 180px;"><img src="@Url.Content("~/Content/images/pic5.jpg")" alt="Business"><h3 class="text-center mt-15">Business English</h3></div>
    </div>
</div>


@* KHỐI 2: MOST POPULAR COURSES *@
<div class="small-container mt-50">
    <h2 class="title">Most Popular Courses</h2>
    <div class="row" style="display: flex; justify-content: space-around; flex-wrap: wrap; gap: 20px;">
        @if (topSubscribedCourses != null && topSubscribedCourses.Any())
        {
            foreach (var item in topSubscribedCourses)
            {
                <div class="col-4 card-box" style="flex: 1; min-width: 280px; max-width: 350px; margin-bottom: 30px; box-shadow: 0 4px 8px rgba(0,0,0,0.05); padding: 15px; border-radius: 10px; background: #fff;">
                    @{
                        string popularImageUrl = "";

                        // 1. Kiểm tra nếu cột Image/ImageUrl trong DB không bị null hoặc rỗng
                        if (item.Image != null && !string.IsNullOrEmpty(item.Image.ToString().Trim()))
                        {
                            string dbImageValue = item.Image.ToString().Trim();

                            // TRƯỜNG HỢP A: Nếu trong DB đã chứa sẵn đường dẫn "Content/images"
                            if (dbImageValue.ToLower().Contains("content/images"))
                            {
                                if (dbImageValue.StartsWith("/"))
                                {
                                    popularImageUrl = "~" + dbImageValue;
                                }
                                else if (dbImageValue.StartsWith("~/"))
                                {
                                    popularImageUrl = dbImageValue;
                                }
                                else
                                {
                                    popularImageUrl = "~/" + dbImageValue;
                                }
                            }
                            // TRƯỜNG HỢP B: Nếu trong DB chỉ lưu mỗi tên file hình được upload mới
                            else
                            {
                                popularImageUrl = "~/Content/images/" + dbImageValue;
                            }
                        }
                        // 2. Nếu cột Image trống -> Dùng logic gán cứu cánh theo CategoryID
                        else
                        {
                            if (item.CategoryID == 1) { popularImageUrl = "~/Content/images/pic1.jpg"; }
                            else if (item.CategoryID == 2) { popularImageUrl = "~/Content/images/pic2.jpg"; }
                            else if (item.CategoryID == 3) { popularImageUrl = "~/Content/images/pic3.jpg"; }
                            else if (item.CategoryID == 4) { popularImageUrl = "~/Content/images/pic4.jpg"; }
                            else if (item.CategoryID == 5) { popularImageUrl = "~/Content/images/pic5.jpg"; }
                            else { popularImageUrl = "~/Content/images/picture1.jpg"; }
                        }
                    }
                    <img src="@Url.Content(popularImageUrl)" alt="@item.CourseName" style="width: 100%; height: 180px; object-fit: cover; border-radius: 8px;">
                    <h4 class="mt-15" style="font-size: 18px; font-weight: 600; color: #333;">@item.CourseName</h4>
                    <p style="color: #764ba2; font-size: 13px; font-weight: 500;" class="mt-5"><i class="fa fa-clock-o"></i> Duration: @item.Duration</p>
                    <p class="mt-10" style="color: #666; font-size: 14px; height: 42px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">@item.Description</p>
                    <p class="mt-15" style="font-weight: 700; color: #ff4757; font-size: 16px;">Price: @string.Format("{0:C0}", item.Price)</p>
                    <a href="@Url.Action("Details", "Course", new { id = item.CourseID })" class="btn btn-primary w-100 mt-15" style="text-align: center; display: block;">View Details</a>
                </div>
            }
        }
        else
        {
            <p class="text-center" style="width: 100%; font-style: italic; color: #888;">No courses available.</p>
        }
    </div>
</div>


@* KHỐI 3: TOP RATED COURSES *@
<div class="small-container mt-50">
    <h2 class="title">Top Rated Courses</h2>
    <div class="row" style="display: flex; justify-content: space-around; flex-wrap: wrap; gap: 20px;">
        @if (topRatedCourses != null && topRatedCourses.Any())
        {
            foreach (var item in topRatedCourses)
            {
                // Ở Khối này, "item" là RatedCourseView nên phải bốc .CourseData ra biến phụ
                var course = item.CourseData;

                <div class="col-4 card-box" style="flex: 1; min-width: 280px; max-width: 350px; margin-bottom: 30px; box-shadow: 0 4px 8px rgba(0,0,0,0.05); padding: 15px; border-radius: 10px; background: #fff;">
                    @{
                        string ratedImageUrl = "";

                        // 1. Kiểm tra dữ liệu ảnh từ đối tượng course phụ
                        if (course.Image != null && !string.IsNullOrEmpty(course.Image.ToString().Trim()))
                        {
                            string dbImageValue = course.Image.ToString().Trim();

                            if (dbImageValue.ToLower().Contains("content/images"))
                            {
                                if (dbImageValue.StartsWith("/"))
                                {
                                    ratedImageUrl = "~" + dbImageValue;
                                }
                                else if (dbImageValue.StartsWith("~/"))
                                {
                                    ratedImageUrl = dbImageValue;
                                }
                                else
                                {
                                    ratedImageUrl = "~/" + dbImageValue;
                                }
                            }
                            else
                            {
                                ratedImageUrl = "~/Content/images/" + dbImageValue;
                            }
                        }
                        else
                        {
                            if (course.CategoryID == 1) { ratedImageUrl = "~/Content/images/pic1.jpg"; }
                            else if (course.CategoryID == 2) { ratedImageUrl = "~/Content/images/pic2.jpg"; }
                            else if (course.CategoryID == 3) { ratedImageUrl = "~/Content/images/pic3.jpg"; }
                            else if (course.CategoryID == 4) { ratedImageUrl = "~/Content/images/pic4.jpg"; }
                            else if (course.CategoryID == 5) { ratedImageUrl = "~/Content/images/pic5.jpg"; }
                            else { ratedImageUrl = "~/Content/images/picture1.jpg"; }
                        }
                    }
                    <img src="@Url.Content(ratedImageUrl)" alt="@course.CourseName" style="width: 100%; height: 180px; object-fit: cover; border-radius: 8px;">
                    <h4 class="mt-15" style="font-size: 18px; font-weight: 600; color: #333;">@course.CourseName</h4>

                    <p style="color: #ffa502; font-size: 14px; font-weight: 600;" class="mt-5">
                        <i class="fa fa-star"></i> @string.Format("{0:0.0}", item.AverageRating) / 5.0 Rating
                    </p>

                    <p class="mt-10" style="color: #666; font-size: 14px; height: 42px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">@course.Description</p>
                    <p class="mt-15" style="font-weight: 700; color: #ff4757; font-size: 16px;">Price: @string.Format("{0:C0}", course.Price)</p>
                    <a href="@Url.Action("Details", "Course", new { id = course.CourseID })" class="btn btn-primary w-100 mt-15" style="text-align: center; display: block;">View Details</a>
                </div>
            }
        }
        else
        {
            <p class="text-center" style="width: 100%; font-style: italic; color: #888;">No highly rated courses yet.</p>
        }
    </div>
</div>


<div class="small-container mt-50" style="background: #f8f9fa; padding: 40px 20px; border-radius: 15px;">
    <h2 class="title">Our Featured Instructors</h2>
    <div class="row">
        <div class="col-3 text-center">
            <img src="@Url.Content("~/Content/images/instructor1.jpg")" style="width: 120px; height: 120px; object-fit: cover; border-radius: 50%; border: 3px solid #764ba2;">
            <h3 class="mt-15">Mr. John Smith</h3>
            <p style="color: #764ba2; font-weight: 600;">Senior IELTS Trainer</p>
            <small style="display: block; color: #666; padding: 0 10px; font-size: 12px;" class="mt-10">8.5 IELTS with over 8 years of experience teaching academic English.</small>
        </div>
        <div class="col-3 text-center">
            <img src="@Url.Content("~/Content/images/instructor2.jpg")" style="width: 120px; height: 120px; object-fit: cover; border-radius: 50%; border: 3px solid #764ba2;">
            <h3 class="mt-15">Ms. Anna Brown</h3>
            <p style="color: #764ba2; font-weight: 600;">TOEIC Trainer</p>
            <small style="display: block; color: #666; padding: 0 10px; font-size: 12px;" class="mt-10">Focus on core grammar and test-taking strategies.</small>
        </div>
        <div class="col-3 text-center">
            <img src="@Url.Content("~/Content/images/instructor3.jpg")" style="width: 120px; height: 120px; object-fit: cover; border-radius: 50%; border: 3px solid #764ba2;">
            <h3 class="mt-15">Ms. Jane Doe</h3>
            <p style="color: #764ba2; font-weight: 600;">Business English Coach</p>
            <small style="display: block; color: #666; padding: 0 10px; font-size: 12px;" class="mt-10">Specialized in corporate workplace communication.</small>
        </div>
    </div>
</div>