<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] | English Mastery</title>
    <link href="~/css/style.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <div class="admin-wrapper">
        <div class="admin-sidebar">
            <div class="sidebar-brand">
                <i class="fa fa-graduation-cap"></i> Trainer Portal
            </div>
            <ul class="sidebar-menu">
                <li class="active"><a href="#"><i class="fa fa-dashboard"></i> Dashboard</a></li>
                <li><a href="#"><i class="fa fa-book"></i> My Courses</a></li>
                <li><a href="#"><i class="fa fa-tasks"></i> Curriculum</a></li>
                <li><a href="#"><i class="fa fa-users"></i> Enrolled Students</a></li>
                <li><a href="#"><i class="fa fa-star"></i> Reviews</a></li>
                <li class="mt-50"><a href="#"><i class="fa fa-sign-out"></i> Logout</a></li>
            </ul>
        </div>

        <div class="admin-content">
            <div class="admin-header">
                <div>
                    <h2>Instructor Command Center</h2>
                    <p class="text-link">Monitor your overall statistics and detailed course metrics.</p>
                </div>
                <div class="user-info">
                    <span class="student-welcome"><i class="fa fa-user-circle"></i> Jane Doe (Instructor Mode)</span>
                </div>
            </div>

            @RenderBody()

        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>