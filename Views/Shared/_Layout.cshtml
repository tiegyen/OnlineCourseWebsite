<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title | English Mastery Portal</title>

    <link href="@Url.Content("~/css/style.css")" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">
</head>
<body>

    <div class="header" style="padding-bottom: 0;">
        <div class="container">
            <div class="navbar" style="display: flex; justify-content: space-between; align-items: center; padding: 15px 0;">
                <div class="logo">
                    <img src="~/Content/images/logo-one.png" width="125px" alt="Logo" />
                </div>
                <nav>
                    <ul id="MenuItems">
                        <li><a href="@Url.Action("Index", "Home")">Home</a></li>

                        @if (Session["UserAccount"] == null)
                        {
                            <li><a href="@Url.Action("Course", "Course")">Courses</a></li>
                            <li><a href="@Url.Action("Register", "User")">Register</a></li>
                            <li><a href="@Url.Action("Login", "User")">Login</a></li>
                        }
                        else
                        {
                            // Đúc tài khoản và profile từ Session ra để xử lý điều hướng
                            var account = Session["UserAccount"] as OnlineCourseWebsite.Models.User_Account;
                            var student = Session["StudentProfile"] as OnlineCourseWebsite.Models.Student;

                            if (account != null && account.Role == "Student")
                            {
                                <li><a href="@Url.Action("MyCourses", "Student")">My Courses</a></li>
                                <li><a href="@Url.Action("Payment", "Student")">Payment</a></li>
                                <li>
                                    <a href="@Url.Action("Profile", "Student")" class="student-welcome" style="font-weight: 600; color: #764ba2;">
                                        <i class="fa fa-user-circle"></i> Welcome, @(student != null ? student.FullName : "Learner")
                                    </a>
                                </li>
                                <li><a href="@Url.Action("Logout", "User")" style="color: #ff523b; font-size: 13px; font-weight: 500;">(Logout)</a></li>
                            }
                            else
                            {
                                <li><a href="@Url.Action("Course", "Course")">Courses</a></li>
                                <li style="color: #4cd137;">Admin Dashboard</li>
                                <li><a href="@Url.Action("Logout", "User")" style="color: #ff523b;">Logout</a></li>
                            }
                        }
                    </ul>
                </nav>
            </div>
        </div>
    </div>

    <div class="main-content">
        @RenderBody()
    </div>

    <div class="footer mt-50">
        <div class="container">
            <div class="row">
                <div class="footer-col-1"><h3>Resources</h3><p>Study anytime, anywhere.</p></div>
                <div class="footer-col-2"><img src="~/Content/images/logo-one.png" alt="Logo"><p>Professional English Training.</p></div>
                <div class="footer-col-3"><h3>Quick Links</h3><ul><li><a href="#">Certifications</a></li><li><a href="#">Support</a></li></ul></div>
            </div>
            <hr />
            <p class="copyright">Copyright 2026 - Team 03 - English Mastery Portal</p>
        </div>
    </div>

</body>
</html>